@using TriStrike.Models
@inject IJSRuntime JSRuntime
@inject TriStrike.Services.GameSettingsService Settings

<div class="cell @(Cell.IsStruck ? "struck" : "") @(Cell.IsStruck ? $"player{Cell.StrikenByPlayer}" : "") @(!Cell.IsStruck && IsMyTurn ? "my-turn" : "") @(Cell.IsAnimating ? "cell-blink" : "") @GetLineClasses()"
     @onclick="HandleClick"
     title="Row @Cell.Row, Col @Cell.Column">
    @if (Cell.IsStruck)
    {
        <span class="strike-mark">✕</span>
        @foreach (var lt in GetLineTypes())
        {
            <span class="line-overlay @lt"></span>
        }
    }
    else
    {
        <span class="cell-zero">0</span>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Cell Cell { get; set; } = default!;

    [Parameter]
    public bool IsMyTurn { get; set; }

    [Parameter]
    public EventCallback<Cell> OnCellClicked { get; set; }

    [CascadingParameter(Name = "GameState")]
    public GameState? GameState { get; set; }

    private CancellationTokenSource? _animCts;

    private async Task HandleClick()
    {
        if (!Cell.IsStruck && IsMyTurn && GameState?.GameOver == false)
        {
            if (Settings.SoundEnabled)
            {
                await JSRuntime.InvokeVoidAsync("triStrike.playFeedback");
            }

            if (Settings.AnimationsEnabled)
            {
                _animCts?.Cancel();
                _animCts = new CancellationTokenSource();
                Cell.IsAnimating = true;
                _ = ResetAnimationAsync(_animCts.Token);
            }

            await OnCellClicked.InvokeAsync(Cell);
        }
    }

    private async Task ResetAnimationAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(2000, token);
            Cell.IsAnimating = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private string GetLineClasses()
    {
        if (!Cell.IsStruck || GameState == null) return "";
        var classes = new HashSet<string>();
        foreach (var line in GameState.CompletedLines)
        {
            if (line.Cells.Any(c => c.Row == Cell.Row && c.Column == Cell.Column))
            {
                classes.Add($"line-{line.Type.ToString().ToLower()}");
            }
        }
        return string.Join(" ", classes);
    }

    private IEnumerable<string> GetLineTypes()
    {
        if (!Cell.IsStruck || GameState == null) yield break;
        var seen = new HashSet<string>();
        foreach (var line in GameState.CompletedLines)
        {
            if (line.Cells.Any(c => c.Row == Cell.Row && c.Column == Cell.Column))
            {
                var lt = $"line-{line.Type.ToString().ToLower()}";
                if (seen.Add(lt))
                    yield return lt;
            }
        }
    }
}
