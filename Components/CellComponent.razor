@using TriStrike.Models

<div class="cell @(Cell.IsStruck ? "struck" : "") @(Cell.IsStruck ? $"player{Cell.StrikenByPlayer}" : "") @(!Cell.IsStruck && IsMyTurn ? "my-turn" : "")"
     @onclick="HandleClick"
     title="Row @Cell.Row, Col @Cell.Column">
    @if (Cell.IsStruck)
    {
        <span class="strike-mark">✕</span>
    }
    else
    {
        <span class="cell-zero">0</span>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Cell Cell { get; set; } = default!;

    [Parameter]
    public bool IsMyTurn { get; set; }

    [Parameter]
    public EventCallback<Cell> OnCellClicked { get; set; }

    [CascadingParameter(Name = "GameState")]
    public GameState? GameState { get; set; }

    private async Task HandleClick()
    {
        if (!Cell.IsStruck && IsMyTurn && GameState?.GameOver == false)
        {
            await OnCellClicked.InvokeAsync(Cell);
        }
    }
}
