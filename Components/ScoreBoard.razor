@using TriStrike.Models
@inject TriStrike.Services.GameSettingsService Settings

<div class="scoreboard">
    <h3>Scoreboard</h3>
    <div class="players">
        @foreach (var player in GameState.Players)
        {
            <div class="player-card @(IsCurrentPlayer(player) ? "active" : "") @(IsMyPlayer(player) ? "my-player" : "")">
                <div class="player-name">
                    @player.Name
                    @if (IsMyPlayer(player))
                    {
                        <span class="you-badge">You</span>
                    }
                    @if (IsCurrentPlayer(player) && !GameState.GameOver)
                    {
                        <span class="turn-indicator">▶ Turn</span>
                    }
                </div>
                <div class="player-score">Score: <strong>@player.Score</strong></div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(GameState.LastMoveMessage))
    {
        <div class="message-toast">
            @GameState.LastMoveMessage
        </div>
    }

    @if (GameState.GameOver)
    {
        var maxScore = GameState.Players.Max(p => p.Score);
        var topPlayers = GameState.Players.Where(p => p.Score == maxScore).ToList();
        <div class="game-over">
            <h4>🏆 Game Over!</h4>
            @if (topPlayers.Count > 1)
            {
                <p>It's a Draw! @string.Join(", ", topPlayers.Select(p => p.Name)) tied with @maxScore points.</p>
            }
            else
            {
                <p><strong>@GameState.Winner?.Name</strong> wins with @GameState.Winner?.Score points!</p>
            }
        </div>
    }

    <div class="completed-lines">
        <h4>Completed Lines (@GameState.CompletedLines.Count)</h4>
        @if (GameState.CompletedLines.Count == 0)
        {
            <p class="no-lines">No lines completed yet.</p>
        }
        else
        {
            <ul>
                @foreach (var line in GameState.CompletedLines.TakeLast(5))
                {
                    <li class="line-entry line-entry-@line.Type.ToString().ToLower()">@line.Type line (length @line.Length)</li>
                }
                @if (GameState.CompletedLines.Count > 5)
                {
                    <li>…and @(GameState.CompletedLines.Count - 5) more</li>
                }
            </ul>
        }
    </div>

    <details class="settings-panel">
        <summary class="settings-summary">⚙️ Settings</summary>
        <div class="settings-content">
            <label class="settings-toggle">
                <input type="checkbox" checked="@Settings.SoundEnabled" @onchange="ToggleSound" />
                🔊 Sound
            </label>
            <label class="settings-toggle">
                <input type="checkbox" checked="@Settings.AnimationsEnabled" @onchange="ToggleAnimations" />
                ✨ Animations
            </label>
        </div>
    </details>
</div>

@code {
    [CascadingParameter(Name = "GameState")]
    public GameState GameState { get; set; } = default!;

    [CascadingParameter(Name = "MyPlayerIndex")]
    public int MyPlayerIndex { get; set; }

    private bool IsCurrentPlayer(Player player)
        => !GameState.GameOver && GameState.Players[GameState.CurrentPlayerIndex].Id == player.Id;

    private bool IsMyPlayer(Player player)
        => player.Id == MyPlayerIndex + 1;

    private void ToggleSound(ChangeEventArgs e)
    {
        Settings.SoundEnabled = e.Value is bool b1 && b1;
        Settings.NotifyChanged();
    }

    private void ToggleAnimations(ChangeEventArgs e)
    {
        Settings.AnimationsEnabled = e.Value is bool b2 && b2;
        Settings.NotifyChanged();
    }
}
