@using TriStrike.Models

<div class="triangle-board">
    @for (int r = 1; r <= GameState.Board.Count; r++)
    {
        var row = r;
        <div class="board-row">
            @for (int c = 1; c <= GameState.Board[row - 1].Count; c++)
            {
                var col = c;
                var cell = GameState.Board[row - 1][col - 1];
                <CellComponent Cell="@cell"
                                IsMyTurn="@IsMyTurn"
                                OnCellClicked="@HandleCellClick" />
            }
        </div>
    }
</div>

@code {
    [CascadingParameter(Name = "GameState")]
    public GameState GameState { get; set; } = default!;

    [CascadingParameter(Name = "MyPlayerIndex")]
    public int MyPlayerIndex { get; set; }

    [Parameter]
    public EventCallback<Cell> OnCellClicked { get; set; }

    private bool IsMyTurn => !GameState.GameOver && GameState.CurrentPlayerIndex == MyPlayerIndex;

    private async Task HandleCellClick(Cell cell)
    {
        if (IsMyTurn && !cell.IsStruck && !GameState.GameOver)
        {
            await OnCellClicked.InvokeAsync(cell);
        }
    }
}
