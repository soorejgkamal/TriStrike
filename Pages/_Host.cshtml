@page "/"
@namespace TriStrike.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;

    // Persist the player's session ID across page reloads using a session
    // cookie.  The cookie is created on the first visit and remains valid
    // until the browser tab is closed.  It is passed to the Blazor root
    // component as a parameter so that SessionService is initialised with
    // the same ID before any child component (e.g. Game.razor) runs its
    // OnInitialized lifecycle hook.
    const string sessionCookieName = "TriStrikeSession";
    // Read the cookie.  If absent, generate a new ID and persist it so that
    // the same value is available on every subsequent request (e.g. reload).
    var cookieSessionId = HttpContext.Request.Cookies[sessionCookieName];
    if (string.IsNullOrEmpty(cookieSessionId))
    {
        cookieSessionId = Guid.NewGuid().ToString("N")[..12];
        HttpContext.Response.Cookies.Append(sessionCookieName, cookieSessionId, new Microsoft.AspNetCore.Http.CookieOptions
        {
            SameSite = Microsoft.AspNetCore.Http.SameSiteMode.Strict,
            IsEssential = true,
            HttpOnly = true,
            Secure = true,
            // No Expires → session cookie; cleared when the browser tab closes.
        });
    }
    // After the block above, cookieSessionId is always a non-null, non-empty string.
    var sessionId = cookieSessionId;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <base href="~/" />
    <title>TriStrike</title>
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="TriStrike.styles.css" rel="stylesheet" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" param-InitialSessionId="@sessionId" />

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.server.js"></script>
    <script>
        window.triStrike = {
            _audioCtx: null,
            _getAudioContext: function () {
                if (!this._audioCtx) {
                    var AudioCtx = window.AudioContext || window.webkitAudioContext;
                    if (!AudioCtx) return null;
                    this._audioCtx = new AudioCtx();
                }
                return this._audioCtx;
            },
            playFeedback: function () {
                this._playClickSound();
                this._vibrate();
            },
            _playClickSound: function () {
                try {
                    var ctx = this._getAudioContext();
                    if (!ctx) return;
                    if (ctx.state === 'suspended') ctx.resume();
                    var osc = ctx.createOscillator();
                    var gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.value = 660;
                    gain.gain.setValueAtTime(0.25, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.12);
                    osc.start(ctx.currentTime);
                    osc.stop(ctx.currentTime + 0.12);
                } catch (e) { }
            },
            _vibrate: function () {
                try {
                    if (navigator.vibrate) navigator.vibrate(50);
                } catch (e) { }
            }
        };
    </script>
</body>
</html>
