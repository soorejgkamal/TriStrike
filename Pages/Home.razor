@page "/"
@inject TriStrike.Services.RoomService RoomService
@inject TriStrike.Services.SessionService SessionService
@inject NavigationManager NavigationManager

<PageTitle>TriStrike</PageTitle>

<h1 class="game-title">⚡ TriStrike</h1>
<p class="game-subtitle">A triangular board game. Complete lines to score points!</p>

@if (mode == "home")
{
    <div class="setup-screen">
        <div class="setup-card">
            <h2 class="setup-title">Multiplayer</h2>
            <div class="home-buttons">
                <button class="start-btn" @onclick='() => SetMode("create")'>🎮 Create Room</button>
                <button class="join-btn"  @onclick='() => SetMode("join")'>🔗 Join Room</button>
            </div>
        </div>
    </div>
}
else if (mode == "create")
{
    <div class="setup-screen">
        <div class="setup-card">
            <h2 class="setup-title">Create Room</h2>

            <div class="setup-field">
                <label class="setup-label">Your Name</label>
                <input class="setup-input" type="text" placeholder="Enter your name" @bind="hostName" @bind:event="oninput" />
            </div>

            <div class="setup-field">
                <label class="setup-label" for="numPlayersSelect">Number of Players</label>
                <select id="numPlayersSelect" class="setup-select" @bind="numPlayers">
                    @for (int n = 2; n <= 6; n++)
                    {
                        <option value="@n">@n Players</option>
                    }
                </select>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-msg">@errorMessage</div>
            }

            <button class="start-btn" @onclick="CreateRoom">▶ Create Room</button>
            <button class="back-btn"  @onclick='() => SetMode("home")'>← Back</button>
        </div>
    </div>
}
else if (mode == "join")
{
    <div class="setup-screen">
        <div class="setup-card">
            <h2 class="setup-title">Join Room</h2>

            <div class="setup-field">
                <label class="setup-label">Room Code</label>
                <input class="setup-input code-input" type="text" placeholder="4-digit code"
                       @bind="joinCode" @bind:event="oninput" maxlength="4" />
            </div>

            <div class="setup-field">
                <label class="setup-label">Your Name</label>
                <input class="setup-input" type="text" placeholder="Enter your name"
                       @bind="joinName" @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-msg">@errorMessage</div>
            }

            <button class="start-btn" @onclick="JoinRoom">🔗 Join Room</button>
            <button class="back-btn"  @onclick='() => SetMode("home")'>← Back</button>
        </div>
    </div>
}

@code {
    private string mode = "home";
    private string hostName = "";
    private int numPlayers = 2;
    private string joinCode = "";
    private string joinName = "";
    private string? errorMessage;

    private void SetMode(string newMode)
    {
        mode = newMode;
        errorMessage = null;
    }

    private async Task CreateRoom()
    {
        if (string.IsNullOrWhiteSpace(hostName))
        {
            errorMessage = "Please enter your name.";
            return;
        }

        var room = RoomService.CreateRoom(numPlayers, hostName, SessionService.SessionId);
        NavigationManager.NavigateTo($"/waiting/{room.RoomCode}");
    }

    private async Task JoinRoom()
    {
        if (string.IsNullOrWhiteSpace(joinCode))
        {
            errorMessage = "Please enter a room code.";
            return;
        }
        if (string.IsNullOrWhiteSpace(joinName))
        {
            errorMessage = "Please enter your name.";
            return;
        }

        var code = joinCode.Trim();
        var (room, error) = RoomService.JoinRoom(code, joinName, SessionService.SessionId);
        if (error != null)
        {
            errorMessage = error;
            return;
        }

        // Notify all waiting players (including Alice) that room state changed.
        // For a 2-player room this auto-navigates Alice to the game page.
        await RoomService.NotifyRoomChangedAsync(room!.RoomCode);

        if (room.IsStarted)
            NavigationManager.NavigateTo($"/game/{room.RoomCode}");
        else
            NavigationManager.NavigateTo($"/waiting/{room.RoomCode}");
    }
}
